#!/bin/bash

OUTPUT_DIR="$HOME/Pictures/Screenshots"

if [[ ! -d "$OUTPUT_DIR" ]]; then
  mkdir -p "$OUTPUT_DIR"
fi

FILENAME="$OUTPUT_DIR/screenshot-$(date +'%Y-%m-%d_%H-%M-%S').png"

# Kill any existing selection tool instances
pkill slurp

# Take screenshot, save to file, and send directly to clipboard
hyprshot -m "${1:-region}" --raw | tee "$FILENAME" | wl-copy --type image/png
