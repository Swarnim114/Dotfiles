# /etc/udev/rules.d/99-trackpad-power.rules
# Fix for I2C trackpad wake-up latency on Asus laptops

# Disable autosuspend for I2C HID devices (trackpads)
ACTION=="add", SUBSYSTEM=="i2c", DRIVERS=="i2c_hid_acpi", ATTR{power/control}="on"

# Disable autosuspend for HID devices
ACTION=="add", SUBSYSTEM=="usb", DRIVER=="usbhid", ATTR{power/control}="on"

# Set autosuspend delay to disabled for input devices
ACTION=="add", SUBSYSTEM=="i2c", ATTR{power/autosuspend_delay_ms}="-1"

# Specifically target Asus trackpad devices
ACTION=="add", ATTRS{name}=="*Asus Trackpad*", ATTR{power/control}="on"
ACTION=="add", ATTRS{name}=="*I2C HID*", ATTR{power/control}="on"
ACTION=="add", ATTRS{name}=="*ELAN*", ATTR{power/control}="on"
ACTION=="add", ATTRS{name}=="*Synaptics*", ATTR{power/control}="on"
