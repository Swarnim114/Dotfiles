{
    "modules-left": ["custom/power", "hyprland/workspaces", "custom/media"],
    "modules-center": [ "clock"],
    "modules-right": ["tray", "bluetooth", "network","custom/powerprofile", "battery","backlight", "pulseaudio"],

  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "оОН",
      "оПФ",
      "оПУ",
      "оПТ",
      "оПС",
      "оПР",
      "оПП",
      "оПО",
      "оПН",
      "оПМ",
      "оПЛ",
      "оПК",
      "оПЙ",
      "оПИ",
      "оОЫ"
    ],
    "scroll-step": 1
  }
,
"pulseaudio#microphone": {
    "format": " {volume}%",
    "format-muted": " {volume}%",
    "on-click": "pavucontrol --tab=4",
    "on-right-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +5%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%",
    "tooltip-format": "Microphone: {volume}%"
}


,

    "custom/power": {
        "format" : "в≠Ш ",
        "tooltip": false,
        "on-click": "wlogout -b 3",
        "tooltip-format": "Power Options"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "cursor": true,
        "on-click": "activate",
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },



"custom/media": {
    "format": "{icon} {text}",
    "max-length": 40,
    "format-icons": {
        "Playing": "рЯОµ",
        "Paused": "вПЄ",
        "Stopped": "вПє"
    },
    "on-click": "playerctl --player=spotify previous",
    "on-click-right": "playerctl --player=spotify next",
    "on-click-middle": "playerctl --player=spotify play-pause",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "exec": "playerctl --player=spotify metadata --format '{{ artist }} - {{ title }}' -F",
    "exec-if": "playerctl --player=spotify status"
}

,
    "tray": {
        "icon-size": 20,
        "spacing": 10,
        "cursor": true,
        "tooltip": true,
        "tooltip-format": "{title}"
    },

    "bluetooth": {
        "format": " у∞Вѓ ",
        "format-disabled": " у∞В≤ ",
        "format-connected": " у∞В± ",
        "on-click": "blueman-manager",
        "tooltip": true,
        "tooltip-format": "Bluetooth: {status}"
    },

    "network": {
        "format-wifi": "пЗЂ  {essid}",
        "format-ethernet": "оЉЙ  Ethernet",
        "format-linked": "пБЮ  Linked (No IP)",
        "format-disconnected": "пБ±  Disconnected",
        "tooltip": true,
        "tooltip-format-wifi": "пЗЂ  {essid}\nSignal: {signalStrength}%\nIP: {ipaddr}",
        "tooltip-format-ethernet": "оЉЙ  Ethernet\nIP: {ipaddr}"
    },

"battery": {
        "states": {
            "good": 85,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-plugged": "пГІ {capacity}%",
        "format-charging": "пГІ {capacity}%",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["пЙД ", "пЙГ ", "пЙВ ", "пЙБ ", "пЙА "],
        "tooltip-format": "Time left: {timeTo}",
        "on-click-right": "~/.config/waybar/scripts/power-profile-toggle.sh toggle" // <--- ADDED 'toggle' argument here
    },

        "custom/powerprofile": {
        "format": "{icon} {text}", // Displays icon then the profile name (e.g., "вЪ° performance")
        "return-type": "json",     // Tells Waybar to expect JSON output from the exec command
        "exec": "~/.config/waybar/scripts/power-profile-toggle.sh get", // Command to get the current profile
        "interval": 2,             // Update every 2 seconds to reflect changes quickly
        "on-click-right": "~/.config/waybar/scripts/power-profile-toggle.sh toggle", // Right-click to toggle profile
        "on-click": "~/.config/waybar/scripts/power-profile-toggle.sh toggle" // Left-click to toggle as well
    },


"pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
    "format-bluetooth-muted": "пЪ© {icon}пКФ {format_source}",
    "format-muted": "пЪ© {format_source}",
    "format-source": "{volume}% пД∞",
    "format-source-muted": "пД±",
    "format-icons": {
        "headphone": "пА• ",
        "hands-free": "пЦР ",
        "headset": "пЦР ",
        "phone": "пВХ ",
        "portable": "пВХ ",
        "car": "пЖє ",
        "default": ["пА¶", "пА®", "пА®"],
        "muted": "пЪ©"
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol"
},

    "cpu": {
        "format": "пТЉ  {usage}%",
        "tooltip": true,
        "tooltip-format": "Usage: {usage}%\nFreq: {frequency} GHz",
        "on-click": "alacritty -e btop" // Or `gnome-system-monitor`, `htop` etc.
    },

"memory": {
        "format": "пГЙ  {used}/{total}G ({percentage}%)", // Ensure this exact format
        "tooltip": true,
        "tooltip-format": "Used: {used}G\nFree: {free}G\nTotal: {total}G",
        "on-click": "alacritty -e btop"
    },
    "temperature": {
        "thermal-zone": 0, // Adjust this if your CPU temp is on a different zone
        "critical-threshold": 80, // Adjust critical temperature threshold
        "format": "пЛЙ {temperatureC}¬∞C",
        "format-critical": "пЛЙ {temperatureC}¬∞C (CRITICAL!)",
        "tooltip": true,
        "tooltip-format": "CPU Temp: {temperatureC}¬∞C"
    },

    "clock": {
        "format": "{:%a %d/%m/%Y ~ %H:%M}",
        "tooltip-format": "<span size='15000'><tt>{calendar}</tt></span>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#F5C2E7'><b>{}</b></span>",
                "weekdays": "<span color='#89B4FA'><b>{}</b></span>",
                "days": "<span color='#CDD6F4'><b>{}</b></span>",
                "today": "<span color='#F9E2AF'><b>{}</b></span>",
            }
        },
        "on-click": "swaync-client -t -sw"
    }
}
