{
  "agent_buffer_font_size": 19.0,
  "cli_default_open_behavior": "new_window",
  "text_rendering_mode": "subpixel",
  "proxy": "",
  "project_panel": {
    "indent_size": 24.0,
    "dock": "left"
  },
  "outline_panel": {
    "indent_size": 24.0,
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "default_profile": "ask",
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "fetch": {
          "default": "allow"
        },
        "terminal": {
          "default": "allow"
        },
        "search_web": {
          "default": "allow"
        }
      }
    },
    "dock": "right",
    "default_model": {
      "effort": "low",
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "vim_mode": false,
  "autosave": "on_focus_change",
  "session": {
    "trust_all_worktrees": true,
  },
  "disable_ai": true,
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/*.out",
  ],
  "icon_theme": {
    "mode": "light",
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Dark"
  },
  "agent_ui_font_size": 19.0,
  "ui_font_family": "CaskaydiaCove Nerd Font Mono",
  "buffer_font_family": "CaskaydiaCove Nerd Font Mono",
  "ui_font_size": 18.0,
  "buffer_font_size": 18.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Colorizer"
  },
  "format_on_save": "off",
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "languages": {
    "JavaScript": {
      "formatter": "prettier",
    },
    "TypeScript": {
      "formatter": "prettier",
    },
  },
}
